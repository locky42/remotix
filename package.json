{
  "name": "remotix-extension",
  "displayName": "Remotix Extension",
  "description": "FTP and SSH client extension for Visual Studio Code",
  "version": "0.1.0",
  "publisher": "locky42",
  "repository": {
    "type": "git",
    "url": "https://github.com/locky42/remotix.git"
  },
  "engines": {
    "vscode": ">=1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:remotix.moreActions",
    "onCommand:remotix.importSshConfig",
    "onCommand:remotix.addConnection",
    "onCommand:remotix.editConnection",
    "onCommand:remotix.openSshTerminal",
    "onCommand:remotix.upload",
    "onCommand:remotix.editFile",
    "onCommand:remotix.deleteFile",
    "onCommand:remotix.rename",
    "onCommand:remotix.copyPath",
    "onCommand:remotix.importFileZilla",
    "onCommand:remotix.deleteConnection",
    "onCommand:remotix.createFile",
    "onCommand:remotix.createFolder",
    "onCommand:remotix.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remotix.addConnection",
        "title": "Remotix: Add connection",
        "icon": "$(add)"
      },
      {
        "command": "remotix.editConnection",
        "title": "Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "remotix.deleteConnection",
        "title": "Delete Connection",
        "icon": "$(trash)"
      },
      {
        "command": "remotix.openSshTerminal",
        "title": "Open SSH Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "remotix.editFile",
        "title": "Edit File",
        "icon": "$(edit)"
      },
      {
        "command": "remotix.upload",
        "title": "Upload",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "remotix.download",
        "title": "Download",
        "icon": "$(cloud-download)"
      },
      {
        "command": "remotix.rename",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "remotix.deleteFile",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "remotix.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "remotix.importSshConfig",
        "title": "Remotix: Import from SSH config"
      },
      {
        "command": "remotix.importFileZilla",
        "title": "Remotix: Import from FileZilla"
      },
      {
        "command": "remotix.moreActions",
        "title": "..."
      },
      {
        "command": "remotix.createFile",
        "title": "Create File",
        "icon": "$(new-file)"
      },
      {
        "command": "remotix.createFolder",
        "title": "Create Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "remotix.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "remotix.addConnection",
          "when": "view == remotixView",
          "group": "navigation@1"
        },
        {
          "command": "remotix.moreActions",
          "when": "view == remotixView",
          "group": "navigation@2",
          "icon": "$(ellipsis)"
        }
      ],
      "view/item/context": [
        {
          "command": "remotix.refresh",
          "when": "view == remotixView && (viewItem == ssh-folder || viewItem == ftp-folder || viewItem == connection || viewItem == connection-active)",
          "group": "inline",
          "icon": "$(refresh)"
        },
        {
          "command": "remotix.createFile",
          "when": "view == remotixView && (viewItem == ssh-folder || viewItem == ssh-file)",
          "group": "0_create@1"
        },
        {
          "command": "remotix.createFolder",
          "when": "view == remotixView && (viewItem == ssh-folder || viewItem == ssh-file)",
          "group": "0_create@2"
        },
        {
          "command": "remotix.editFile",
          "when": "view == remotixView && viewItem == ssh-file",
          "group": "navigation"
        },
        {
          "command": "remotix.openSshTerminal",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "navigation"
        },
        {
          "command": "remotix.editConnection",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "1_connection"
        },
        {
          "command": "remotix.copyPath",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder)",
          "group": "2_path"
        },
        {
          "command": "remotix.upload",
          "when": "view == remotixView && viewItem == ssh-folder",
          "group": "3_transfer"
        },
        {
          "command": "remotix.upload",
          "when": "view == remotixView && viewItem == ftp-folder",
          "group": "3_transfer"
        },
        {
          "command": "remotix.download",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder || viewItem == ftp-file || viewItem == ftp-folder)",
          "group": "3_transfer"
        },
        {
          "command": "remotix.rename",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder)",
          "group": "4_modification@1"
        },
        {
          "command": "remotix.deleteFile",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder)",
          "group": "4_modification@2"
        },
        {
          "command": "remotix.deleteConnection",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "4_modification@3"
        },
        {
          "command": "remotix.createFile",
          "when": "view == remotixView && (viewItem == ftp-folder || viewItem == ftp-file)",
          "group": "0_create@1"
        },
        {
          "command": "remotix.createFolder",
          "when": "view == remotixView && (viewItem == ftp-folder || viewItem == ftp-file)",
          "group": "0_create@2"
        },
        {
          "command": "remotix.editFile",
          "when": "view == remotixView && viewItem == ftp-file",
          "group": "navigation"
        },
        {
          "command": "remotix.rename",
          "when": "view == remotixView && (viewItem == ftp-file || viewItem == ftp-folder)",
          "group": "4_modification@1"
        },
        {
          "command": "remotix.deleteFile",
          "when": "view == remotixView && (viewItem == ftp-file || viewItem == ftp-folder)",
          "group": "4_modification@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "remotix-activitybar",
          "title": "Remotix",
          "icon": "media/remotix-icon.svg"
        }
      ]
    },
    "views": {
      "remotix-activitybar": [
        {
          "id": "remotixView",
          "name": "Remotix Panel",
          "icon": "media/remotix-icon.svg",
          "dragAndDropController": true
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-static",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "copy-static": "rm -rf ./out/static && mkdir -p ./out/static && cp -rf ./src/static/* ./out/static/"
  },
  "dependencies": {
    "basic-ftp": "^5.2.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.70.0",
    "eslint": "^8.0.0",
    "typescript": "^4.7.0"
  }
}
