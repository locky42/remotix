{
  "name": "remotix-extension",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "locky42",
  "repository": {
    "type": "git",
    "url": "https://github.com/locky42/remotix.git"
  },
  "engines": {
    "vscode": ">=1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:remotix.moreActions",
    "onCommand:remotix.importSshConfig",
    "onCommand:remotix.addConnection",
    "onCommand:remotix.editConnection",
    "onCommand:remotix.openSshTerminal",
    "onCommand:remotix.upload",
    "onCommand:remotix.editFile",
    "onCommand:remotix.deleteFile",
    "onCommand:remotix.rename",
    "onCommand:remotix.copyPath",
    "onCommand:remotix.importFileZilla",
    "onCommand:remotix.deleteConnection",
    "onCommand:remotix.closeConnection",
    "onCommand:remotix.setLanguage",
    "onCommand:remotix.openSettings",
    "onCommand:remotix.createFile",
    "onCommand:remotix.createFolder",
    "onCommand:remotix.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remotix.addConnection",
        "title": "%command.addConnection%",
        "icon": "$(add)"
      },
      {
        "command": "remotix.editConnection",
        "title": "%command.editConnection%",
        "icon": "$(edit)"
      },
      {
        "command": "remotix.deleteConnection",
        "title": "%command.deleteConnection%",
        "icon": "$(trash)"
      },
      {
        "command": "remotix.closeConnection",
        "title": "%command.closeConnection%",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "remotix.openSshTerminal",
        "title": "%command.openSshTerminal%",
        "icon": "$(terminal)"
      },
      {
        "command": "remotix.editFile",
        "title": "%command.editFile%",
        "icon": "$(edit)"
      },
      {
        "command": "remotix.upload",
        "title": "%command.upload%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "remotix.download",
        "title": "%command.download%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "remotix.rename",
        "title": "%command.rename%",
        "icon": "$(edit)"
      },
      {
        "command": "remotix.deleteFile",
        "title": "%command.deleteFile%",
        "icon": "$(trash)"
      },
      {
        "command": "remotix.copyPath",
        "title": "%command.copyPath%"
      },
      {
        "command": "remotix.importSshConfig",
        "title": "%command.importSshConfig%"
      },
      {
        "command": "remotix.importFileZilla",
        "title": "%command.importFileZilla%"
      },
      {
        "command": "remotix.setLanguage",
        "title": "%command.setLanguage%",
        "icon": "$(globe)"
      },
      {
        "command": "remotix.openSettings",
        "title": "%command.openSettings%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "remotix.moreActions",
        "title": "..."
      },
      {
        "command": "remotix.createFile",
        "title": "%command.createFile%",
        "icon": "$(new-file)"
      },
      {
        "command": "remotix.createFolder",
        "title": "%command.createFolder%",
        "icon": "$(new-folder)"
      },
      {
        "command": "remotix.refresh",
        "title": "%command.refresh%",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "remotix.addConnection",
          "when": "view == remotixView",
          "group": "navigation@1"
        },
        {
          "command": "remotix.openSettings",
          "when": "view == remotixView",
          "group": "navigation@2",
          "icon": "$(settings-gear)"
        },
        {
          "command": "remotix.moreActions",
          "when": "view == remotixView",
          "group": "navigation@3",
          "icon": "$(ellipsis)"
        }
      ],
      "view/item/context": [
        {
          "command": "remotix.refresh",
          "when": "view == remotixView && (viewItem == ssh-folder || viewItem == ftp-folder || viewItem == connection || viewItem == connection-active)",
          "group": "inline",
          "icon": "$(refresh)"
        },
        {
          "command": "remotix.closeConnection",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "inline",
          "icon": "$(debug-disconnect)"
        },
        {
          "command": "remotix.createFile",
          "when": "view == remotixView && (viewItem == ssh-folder || viewItem == ssh-file)",
          "group": "0_create@1"
        },
        {
          "command": "remotix.createFolder",
          "when": "view == remotixView && (viewItem == ssh-folder || viewItem == ssh-file)",
          "group": "0_create@2"
        },
        {
          "command": "remotix.editFile",
          "when": "view == remotixView && viewItem == ssh-file",
          "group": "navigation"
        },
        {
          "command": "remotix.openSshTerminal",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "navigation"
        },
        {
          "command": "remotix.editConnection",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "1_connection"
        },
        {
          "command": "remotix.closeConnection",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "1_connection"
        },
        {
          "command": "remotix.copyPath",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder)",
          "group": "2_path"
        },
        {
          "command": "remotix.upload",
          "when": "view == remotixView && viewItem == ssh-folder",
          "group": "3_transfer"
        },
        {
          "command": "remotix.upload",
          "when": "view == remotixView && viewItem == ftp-folder",
          "group": "3_transfer"
        },
        {
          "command": "remotix.download",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder || viewItem == ftp-file || viewItem == ftp-folder)",
          "group": "3_transfer"
        },
        {
          "command": "remotix.rename",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder)",
          "group": "4_modification@1"
        },
        {
          "command": "remotix.deleteFile",
          "when": "view == remotixView && (viewItem == ssh-file || viewItem == ssh-folder)",
          "group": "4_modification@2"
        },
        {
          "command": "remotix.deleteConnection",
          "when": "view == remotixView && (viewItem == connection || viewItem == connection-active)",
          "group": "4_modification@3"
        },
        {
          "command": "remotix.createFile",
          "when": "view == remotixView && (viewItem == ftp-folder || viewItem == ftp-file)",
          "group": "0_create@1"
        },
        {
          "command": "remotix.createFolder",
          "when": "view == remotixView && (viewItem == ftp-folder || viewItem == ftp-file)",
          "group": "0_create@2"
        },
        {
          "command": "remotix.editFile",
          "when": "view == remotixView && viewItem == ftp-file",
          "group": "navigation"
        },
        {
          "command": "remotix.rename",
          "when": "view == remotixView && (viewItem == ftp-file || viewItem == ftp-folder)",
          "group": "4_modification@1"
        },
        {
          "command": "remotix.deleteFile",
          "when": "view == remotixView && (viewItem == ftp-file || viewItem == ftp-folder)",
          "group": "4_modification@2"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "remotix.language": {
          "type": "string",
          "default": "auto",
          "order": 1,
          "enum": [
            "auto",
            "en",
            "uk"
          ],
          "enumItemLabels": [
            "%config.language.item.auto%",
            "%config.language.item.en%",
            "%config.language.item.uk%"
          ],
          "description": "%config.language.description%"
        },
        "remotix.ftpUploadConcurrency": {
          "type": "number",
          "default": 3,
          "order": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "%config.ftpUploadConcurrency.description%"
        },
        "remotix.ftpDownloadConcurrency": {
          "type": "number",
          "default": 3,
          "order": 2,
          "minimum": 1,
          "maximum": 10,
          "description": "%config.ftpDownloadConcurrency.description%"
        },
        "remotix.sshUploadConcurrency": {
          "type": "number",
          "default": 3,
          "order": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "%config.sshUploadConcurrency.description%"
        },
        "remotix.sshDownloadConcurrency": {
          "type": "number",
          "default": 4,
          "order": 4,
          "minimum": 1,
          "maximum": 10,
          "description": "%config.sshDownloadConcurrency.description%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "remotix-activitybar",
          "title": "%view.container.title%",
          "icon": "media/remotix-icon.svg"
        }
      ]
    },
    "views": {
      "remotix-activitybar": [
        {
          "id": "remotixView",
          "name": "%view.panel.name%",
          "icon": "media/remotix-icon.svg",
          "dragAndDropController": true
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-static",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "copy-static": "rm -rf ./out/static && mkdir -p ./out/static && cp -rf ./src/static/* ./out/static/"
  },
  "dependencies": {
    "basic-ftp": "^5.2.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.70.0",
    "eslint": "^8.0.0",
    "typescript": "^4.7.0"
  }
}
